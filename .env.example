# --- AMASS (clinical trials / literature / patents retrieval) ---
AMASS_API_KEY=amass_your_key_here
AMASS_BASE_URL=https://api.amass.tech/api/v1

# --- Elicit (literature + clinical trials; NOT patents) ---
# Pro plan or above; create the key in Elicit account settings.
ELICIT_API_KEY=elk_live_your_key_here

# --- Supabase (backend for the Prognosis UI) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your_anon_key           # used by the web app (read-only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # used by pipeline/load_prognosis.py

# Open Targets needs no key (public GraphQL API).
